# Promise Pipeline — Environment Variables
# Copy this file to .env.local and fill in your values

# Required for annotation tool (Claude-powered promise extraction)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional — higher rate limits for bill search (works without it)
OPENSTATES_API_KEY=your-openstates-api-key-here

# Sanity CMS (required for blog/content pages)
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# Resend (required for contact/inquiry form)
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=Promise Pipeline <you@yourdomain.com>
