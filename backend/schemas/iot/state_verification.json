{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IoT State Verification",
  "description": "Promise schema for verifying IoT device state matches expected state",
  "type": "object",
  "properties": {
    "device_id": {
      "type": "string",
      "description": "Unique identifier for the IoT device"
    },
    "device_type": {
      "type": "string",
      "description": "Type of device (e.g., 'smart_lock', 'thermostat', 'camera')"
    },
    "expected_state": {
      "type": "object",
      "description": "The state the device promised to be in",
      "properties": {
        "attribute": {
          "type": "string",
          "description": "State attribute being verified (e.g., 'locked', 'temperature')"
        },
        "value": {
          "description": "Expected value for the attribute"
        }
      }
    },
    "actual_state": {
      "type": "object",
      "description": "The actual state reported by the device",
      "properties": {
        "attribute": {
          "type": "string"
        },
        "value": {
          "description": "Actual value for the attribute"
        }
      }
    },
    "verification_method": {
      "type": "string",
      "enum": ["sensor_reading", "api_query", "physical_inspection", "network_probe"],
      "description": "How the state was verified"
    },
    "state_matches": {
      "type": "boolean",
      "description": "Whether actual state matches expected state"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When the verification was performed"
    },
    "location": {
      "type": "string",
      "description": "Physical location of the device (optional)"
    }
  },
  "required": ["device_id", "device_type", "expected_state", "actual_state", "verification_method", "state_matches", "timestamp"]
}
